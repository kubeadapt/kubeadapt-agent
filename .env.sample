# KubeAdapt Agent Configuration
# Copy this file to .env and fill in the values.

# ============================================================================
# CORE (Required)
# ============================================================================

# (Required) API key for authenticating with the KubeAdapt backend.
KUBEADAPT_API_KEY=

# ============================================================================
# BACKEND COMMUNICATION (Optional)
# ============================================================================

# KubeAdapt backend API endpoint.
# KUBEADAPT_BACKEND_URL=https://api.kubeadapt.io

# ============================================================================
# INTERVALS (Optional)
# ============================================================================

# Interval between cluster state snapshots (Go duration or seconds). Min: 10s.
# KUBEADAPT_SNAPSHOT_INTERVAL=60s

# Interval between metrics collection (Go duration or seconds). Min: 10s.
# KUBEADAPT_METRICS_INTERVAL=60s

# Kubernetes informer resync period (Go duration or seconds).
# KUBEADAPT_INFORMER_RESYNC=300s

# Timeout for Kubernetes informer sync (Go duration or seconds).
# KUBEADAPT_INFORMER_SYNC_TIMEOUT=5m

# Interval for GPU metrics collection (Go duration or seconds). Defaults to KUBEADAPT_METRICS_INTERVAL.
# KUBEADAPT_GPU_METRICS_INTERVAL=60s

# ============================================================================
# TRANSPORT (Optional)
# ============================================================================

# Compression level for data sent to backend (1-4).
# KUBEADAPT_COMPRESSION_LEVEL=3

# Max retry attempts for failed backend requests.
# KUBEADAPT_MAX_RETRIES=5

# Timeout for HTTP requests to backend (Go duration or seconds).
# KUBEADAPT_REQUEST_TIMEOUT=30s

# Max buffer size in bytes (default: 50 MB).
# KUBEADAPT_BUFFER_MAX_BYTES=52428800

# ============================================================================
# HEALTH & DEBUG (Optional)
# ============================================================================

# HTTP port for the health check endpoint (1-65535).
# KUBEADAPT_HEALTH_PORT=8080

# Allow insecure HTTP connections to backend (default: false).
# KUBEADAPT_ALLOW_INSECURE=false

# Enable debug endpoints (pprof, debug) on health port (default: false).
# KUBEADAPT_DEBUG_ENDPOINTS=false

# ============================================================================
# GPU MONITORING (Optional)
# ============================================================================

# Enable GPU metrics collection (default: true).
# KUBEADAPT_GPU_METRICS_ENABLED=true

# Port for DCGM exporter (default: 9400).
# KUBEADAPT_DCGM_PORT=9400

# Kubernetes namespace for DCGM exporter (auto-detect if empty).
# KUBEADAPT_DCGM_NAMESPACE=

# Comma-separated list of DCGM exporter endpoints for local dev override (e.g., "10.0.0.1:9400,10.0.0.2:9400").
# KUBEADAPT_DCGM_ENDPOINTS=

# ============================================================================
# VERSION (Optional)
# ============================================================================

# Agent version (set by Helm/runtime, falls back to build-time version).
# KUBEADAPT_AGENT_VERSION=
